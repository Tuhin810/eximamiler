# ---- Delivery ----
# submission = forward to SMARTHOST | direct-mx = deliver straight to MX
DELIVERY_MODE=submission

# ---- This node's identity ----
PRIMARY_HOSTNAME=mail.yourdomain.com
SUBMISSION_PORT=587

# ---- App submission account (Repo 1 authenticates with these) ----
APP_SMTP_USER=proxymailer
APP_SMTP_PASS=change-me-strong-secret

# ---- DKIM (colon-separate multiple domains) ----
DKIM_SELECTOR=proxymail
DKIM_DOMAINS=yourdomain.com

# ---- Smarthost (only used when DELIVERY_MODE=submission) ----
SMARTHOST=smtp-relay.brevo.com::587
SMARTHOST_USER=
SMARTHOST_PASS=

# ---- Management API ----
MGMT_PORT=8443
MGMT_TOKEN=change-me-mgmt-token
